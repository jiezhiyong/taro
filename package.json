    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "babel-plugin-import": "^1.13.8",
    "babel-plugin-transform-define": "^2.1.4",
    "babel-preset-taro": "^4.2.0",
    "sass": "^1.98.0",
