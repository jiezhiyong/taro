    "@tarojs/react": "^4.2.0",
    "@tarojs/runtime": "^4.2.0",
    "@tarojs/shared": "^4.2.0",
    "@tarojs/taro": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
