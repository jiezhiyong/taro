{
  "name": "taro-showcase",
  "version": "1.0.0",
  "private": true,
  "description": "Taro + React showcase",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:weapp:mock": "MOCK=1 taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
    "dev:h5:mock": "MOCK=1 taro build --type h5 --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
